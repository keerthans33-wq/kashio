generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// Stores the Basiq user ID created when a user connects their bank.
// Single-row for MVP — one user, one connection.
model BasiqConnection {
  id          String   @id @default(cuid())
  basiqUserId String   @unique
  createdAt   DateTime @default(now())
}

model ImportBatch {
  id           String        @id @default(cuid())
  fileName     String
  insertedCount Int
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id                 String              @id @default(cuid())
  date               String              // always stored as YYYY-MM-DD — normalised by parseDate before insert
  description        String              // raw bank description
  normalizedMerchant String              // cleaned merchant name
  amount             Float               // negative = debit, positive = credit
  createdAt          DateTime            @default(now())
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  importBatchId      String?
  deductionCandidate DeductionCandidate?

  @@unique([date, description, amount])
}

// How confident the detection rule is that this transaction is a deduction.
enum Confidence {
  LOW
  MEDIUM
  HIGH
}

// What the user has decided about this candidate.
enum DeductionStatus {
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
}

model DeductionCandidate {
  id            String          @id @default(cuid())
  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  transactionId String          @unique  // one candidate per transaction for MVP
  category      String          // e.g. "Work Software & Tools"
  confidence    Confidence
  reason        String          // short explanation, e.g. "Matches known software subscription"
  status        DeductionStatus @default(NEEDS_REVIEW)
  hasEvidence   Boolean         @default(false)
  evidenceNote  String?         // optional free text, e.g. "Bunnings receipt Feb 2025"
  createdAt     DateTime        @default(now())
}
