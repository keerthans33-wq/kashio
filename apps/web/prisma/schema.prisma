generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id                 String   @id @default(cuid())
  date               String   // always stored as YYYY-MM-DD — normalised by parseDate before insert
  description        String   // raw bank description
  normalizedMerchant String   // cleaned merchant name
  amount             Float    // negative = debit, positive = credit
  createdAt          DateTime @default(now())

  @@unique([date, description, amount])
}
