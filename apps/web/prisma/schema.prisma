generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// Stores the Basiq user ID created when a user connects their bank.
model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique              // Supabase user ID
  reportUnlocked     Boolean  @default(false)
  receiptCount       Int      @default(0)
  welcomeEmailSent   Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model Receipt {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid                 @map("user_id")
  fileUrl   String   @map("file_url")
  filePath  String   @map("file_path")
  fileName  String   @map("file_name")
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")
  comment   String?  @map("comment")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("receipts")
}

// BankConnection replaces the earlier BasiqConnection model.
// Keyed by (userId, provider) so the same user can link multiple providers later.
// status values: "active" | "disconnected" | "error"
model BankConnection {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  provider        String        @default("basiq")   @map("provider")
  basiqUserId     String?       @map("basiq_user_id") // null for non-Basiq providers
  status          String        @default("active")   @map("status")
  institutionName String?       @map("institution_name")
  lastSyncAt      DateTime?     @map("last_sync_at") @db.Timestamptz
  createdAt       DateTime      @default(now())      @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt           @map("updated_at") @db.Timestamptz
  syncLogs        BankSyncLog[]

  @@unique([userId, provider])
  @@map("bank_connections")
}

// BankSyncLog records every sync attempt for a BankConnection.
// status values: "started" | "success" | "error"
model BankSyncLog {
  id                   String         @id @default(cuid())
  userId               String         @map("user_id")
  connectionId         String         @map("connection_id")
  status               String         @default("started")  @map("status")
  message              String?        @map("message")
  transactionsImported Int            @default(0)          @map("transactions_imported")
  startedAt            DateTime       @default(now())      @map("started_at")   @db.Timestamptz
  completedAt          DateTime?      @map("completed_at") @db.Timestamptz
  connection           BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@map("bank_sync_logs")
}

model ImportBatch {
  id            String            @id @default(cuid())
  userId        String                           // Supabase user ID — scopes this batch to one user
  fileName      String
  insertedCount Int
  source        TransactionSource @default(CSV)
  createdAt     DateTime          @default(now())
  transactions  Transaction[]
}

model Transaction {
  id                 String              @id @default(cuid())
  userId             String                           // Supabase user ID — scopes this transaction to one user
  date               String              // always stored as YYYY-MM-DD — normalised by parseDate before insert
  description        String              // raw bank description
  normalizedMerchant String              // cleaned merchant name
  amount             Float               // negative = debit, positive = credit
  source             TransactionSource   @default(CSV)
  createdAt          DateTime            @default(now())
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  importBatchId      String?
  deductionCandidate DeductionCandidate?

  // Bank-specific fields — nullable so CSV rows are unaffected.
  // merchant_clean: intentionally omitted — normalizedMerchant already stores the
  //   cleaned name, using Basiq's merchant.businessName when available.
  // source enum: existing CSV | DEMO_BANK | BASIQ covers 'csv' | 'bank' distinction.
  providerTransactionId String? // Basiq transaction ID; unique per user when set
  rawProviderData       Json?   // raw Basiq response payload for auditing
  isPending             Boolean @default(false) // true for pending/unsettled transactions
  accountId             String? // bank account ID from the provider
  transactionHash       String? // content-based hash for dedup when providerTransactionId is unavailable

  // No unique constraint here — within-batch duplicates are intentionally allowed
  // (e.g. two identical $9.99 charges on the same day in one CSV are real distinct transactions).
  // Cross-batch duplicate detection is done at the application level in importPipeline.ts.
  // Bank dedup uses partial unique indexes on providerTransactionId and transactionHash
  // (WHERE NOT NULL), defined in the migration SQL.
  @@index([userId, date, description, amount])
}

// Where the transaction came from.
enum TransactionSource {
  CSV
  DEMO_BANK
  BASIQ
}

// How confident the detection rule is that this transaction is a deduction.
enum Confidence {
  LOW
  MEDIUM
  HIGH
}

// Classifier suggestion: how work-related the transaction appears.
enum SuggestionLevel {
  LIKELY_WORK_RELATED
  POSSIBLE_WORK_RELATED
  PROBABLY_PERSONAL
}

// What the user has decided about this candidate.
enum DeductionStatus {
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
  MAYBE
}

model WfhLog {
  id        String   @id @default(cuid())
  userId    String                           // Supabase user ID
  date      String                           // YYYY-MM-DD
  hours     Float
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, date])
}

model Payment {
  id                    String   @id @default(cuid())
  userId                String
  stripeSessionId       String   @unique
  stripePaymentIntentId String?
  amountTotal           Int
  currency              String   @default("aud")
  paymentStatus         String   @default("paid")
  createdAt             DateTime @default(now())

  @@index([userId])
}

model UserEntitlement {
  id         String   @id @default(cuid())
  userId     String
  productKey String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, productKey])
  @@index([userId])
}

model DeductionCandidate {
  id            String          @id @default(cuid())
  userId        String                           // Supabase user ID — scopes this candidate to one user
  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  transactionId String          @unique  // one candidate per transaction for MVP
  category      String          // e.g. "Work Software & Tools"
  confidence    Confidence
  reason              String          // short explanation, e.g. "Matches known software subscription"
  confidenceReason    String?         // explains why confidence is LOW/MEDIUM/HIGH
  mixedUse            Boolean         @default(false) // true if category may include personal use
  suggestionLevel     SuggestionLevel @default(PROBABLY_PERSONAL)
  status        DeductionStatus @default(NEEDS_REVIEW)
  hasEvidence   Boolean         @default(false)
  evidenceNote  String?         // optional free text, e.g. "Bunnings receipt Feb 2025"
  workPercent   Int?            // 0-100 work-use split; null = full amount; claimable = amount × (workPercent/100)
  score         Int             @default(50) // 0-100 confidence score; drives reviewRequired and excludeFromEstimate
  createdAt     DateTime        @default(now())
}
