# PostgreSQL connection string
# Replace with your actual database URL before running migrations

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kashio?schema=public"

# Basiq Open Banking API key — get yours at https://dashboard.basiq.io
BASIQ_API_KEY="your-basiq-api-key-here"

# ─── Ollama (optional) ────────────────────────────────────────────────────────
# Local LLM refinement layer — secondary pass for LOW-confidence matches only.
# Kashio works fully without this; set OLLAMA_ENABLED=true to activate.
#
# 1. Install Ollama: https://ollama.com
# 2. Pull a model:   ollama pull mistral
# 3. Start server:   ollama serve
# 4. Enable here:    OLLAMA_ENABLED=true
#
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
