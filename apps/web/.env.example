# PostgreSQL connection string
# Replace with your actual database URL before running migrations

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kashio?schema=public"

# Basiq Open Banking API key — get yours at https://dashboard.basiq.io
BASIQ_API_KEY="your-basiq-api-key-here"

# ─── Gemini (optional) ────────────────────────────────────────────────────────
# Secondary refinement pass for LOW-confidence rule-engine matches.
# Kashio works fully without this; set GEMINI_ENABLED=true to activate.
#
# 1. Get an API key: https://aistudio.google.com/apikey
# 2. Set GEMINI_ENABLED=true and GEMINI_API_KEY below
# 3. Optionally override the model (default: gemini-2.0-flash)
#
GEMINI_ENABLED=false
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL=gemini-2.0-flash

# ─── Stripe (required for Kashio Pro) ────────────────────────────────────────
# Kashio Pro is a subscription: $4.99/month or $39.99/year (AUD).
# One subscription unlocks everything: export, all deductions, 100 receipts, full dashboard.
#
# Setup:
# 1. Create a product at https://dashboard.stripe.com/products
#    - Product name: "Kashio Pro"
# 2. Create two recurring prices under that product:
#    - Monthly: A$4.99/month, currency AUD, tax behavior Exclusive
#    - Annual:  A$39.99/year, currency AUD, tax behavior Exclusive
# 3. Enable Stripe Tax + register Australia as your origin:
#    https://dashboard.stripe.com/tax/registrations
# 4. Add a webhook endpoint at https://app.kashio.com.au/api/stripe/webhook
#    Events required:
#      - checkout.session.completed
#      - customer.subscription.deleted
#
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Monthly price ID (A$4.99/month)
STRIPE_MONTHLY_PRICE_ID="price_..."
# Annual price ID (A$39.99/year)
STRIPE_ANNUAL_PRICE_ID="price_..."
# Legacy: used as fallback if STRIPE_MONTHLY_PRICE_ID / STRIPE_ANNUAL_PRICE_ID are not set
STRIPE_PRICE_ID="price_..."

# App public URL — used to build success_url / cancel_url in checkout
NEXT_PUBLIC_APP_URL="https://app.kashio.com.au"

