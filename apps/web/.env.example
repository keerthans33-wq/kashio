# PostgreSQL connection string
# Replace with your actual database URL before running migrations

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kashio?schema=public"

# Basiq Open Banking API key — get yours at https://dashboard.basiq.io
BASIQ_API_KEY="your-basiq-api-key-here"

# ─── Gemini (optional) ────────────────────────────────────────────────────────
# Secondary refinement pass for LOW-confidence rule-engine matches.
# Kashio works fully without this; set GEMINI_ENABLED=true to activate.
#
# 1. Get an API key: https://aistudio.google.com/apikey
# 2. Set GEMINI_ENABLED=true and GEMINI_API_KEY below
# 3. Optionally override the model (default: gemini-2.0-flash)
#
GEMINI_ENABLED=false
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL=gemini-2.0-flash

# ─── Stripe (required for report unlock) ─────────────────────────────────────
# 1. Create a product + one-time AUD price at https://dashboard.stripe.com/products
#    - Product name: "Kashio Tax Summary Report"
#    - Price: A$19.99 one-time, currency AUD
#    - Tax behavior: Exclusive (GST added on top)
# 2. Enable Stripe Tax + register Australia as your origin
#    https://dashboard.stripe.com/tax/registrations
# 3. Add a webhook endpoint at https://app.kashio.com.au/api/stripe/webhook
#    Events required: checkout.session.completed
#
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Primary price ID env var (canonical)
STRIPE_PRICE_ID="price_..."
# Legacy alias — STRIPE_PRICE_ID takes precedence if both are set
STRIPE_PRICE_ID_TAX_SUMMARY="price_..."

# App public URL — used to build success_url / cancel_url in checkout
NEXT_PUBLIC_APP_URL="https://app.kashio.com.au"

