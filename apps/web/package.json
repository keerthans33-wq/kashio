{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "seed:empty": "tsx prisma/seed.ts --state empty",
    "seed:imported": "tsx prisma/seed.ts --state imported",
    "seed:reviewed": "tsx prisma/seed.ts --state reviewed",
    "seed:confirmed": "tsx prisma/seed.ts --state confirmed",
    "seed:export-ready": "tsx prisma/seed.ts --state export-ready",
    "cap:sync": "cap sync"
  },
  "dependencies": {
    "@capacitor/camera": "^8.2.0",
