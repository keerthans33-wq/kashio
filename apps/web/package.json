{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet. Add a test runner when ready.\" && exit 0",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "seed:empty": "tsx prisma/seed.ts --state empty",
    "seed:imported": "tsx prisma/seed.ts --state imported",
    "seed:reviewed": "tsx prisma/seed.ts --state reviewed",
    "seed:confirmed": "tsx prisma/seed.ts --state confirmed",
    "seed:export-ready": "tsx prisma/seed.ts --state export-ready"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.101.1",
    "@types/react-pdf": "^6.2.0",
    "exceljs": "^4.4.0",
    "next": "16.2.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
